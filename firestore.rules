rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check custom claim first (set server-side), then fall back to
    // the /admins/{uid} document so the app works without server-side
    // claim provisioning.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == "admin" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── admins ────────────────────────────────────────────────────────────
    // Readable by any authenticated user (needed for the get() call above
    // which runs in security rule evaluation context).  Only admins can
    // write this collection.

    match /admins/{adminId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Users may update only safe profile fields.
      // ALL loyalty/tier/role fields are exclusively written by backend
      // (API routes using Admin SDK) or admin panel.
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny([
                            'loyaltyPoints', 'totalCoinsEarned',
                            'tierCoins',
                            'annualOmniaValue', 'lifetimeOmniaValue',
                            'annualResetDate', 'tier', 'tierUpdatedAt',
                            'tierOverriddenByAdmin', 'role', 'travelFamily',
                            'travelFamilyAssignedAt', 'totalPackages',
                            'totalSpend', 'referredBy', 'referralCode',
                            'referralCodeUsed', 'totalReferrals'
                          ]))
                    || isAdmin();
      allow delete: if isAdmin();

      // coinsHistory — ADMIN ONLY writes (system writes via Admin SDK bypass rules).
      // Users can only read their own history. No client-side coin creation allowed.
      match /coinsHistory/{txId} {
        allow read:   if isOwner(userId) || isAdmin();
        // Field-level validation prevents fabricated entries even if owner attempts write:
        // - type must not be 'booking' (only system awards booking coins)
        // - coins must be positive (no manual negative manipulation)
        // - affectsTier must be false (tier-affecting coins come from system only)
        allow create: if isAdmin() ||
          (isOwner(userId)
           && request.resource.data.keys().hasAll(['coins', 'type', 'affectsTier', 'reason'])
           && request.resource.data.coins is int
           && request.resource.data.coins >= 0
           && request.resource.data.affectsTier == false
           && !(request.resource.data.type in ['booking', 'admin_adjustment', 'manual', 'welcome_bonus', 'bonus'])
          );
        allow update: if isAdmin();   // clients may NOT update history records
        allow delete: if false;
      }

      // tierHistory — append-only log of tier changes
      match /tierHistory/{entryId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if false;
        allow delete: if false;
      }

      // favorites — user's favorite packages
      match /favorites/{packageId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow write:  if isOwner(userId) || isAdmin();
      }

      // passport — stores passport file URL, expiry date, uploadedAt
      match /passport/{docId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow write:  if isOwner(userId) || isAdmin();
      }
    }

    // ── packages ──────────────────────────────────────────────────────────

    match /packages/{packageId} {
      allow read:   if resource.data.status == "published" || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── tours ─────────────────────────────────────────────────────────────

    match /tours/{tourId} {
      allow read:   if resource.data.status == "published" || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── bookings ──────────────────────────────────────────────────────────
    // Users create their own bookings; critical financial fields must not
    // be set or modified by the client.
    // All payment/status/loyalty updates go through Admin SDK (API routes).

    match /bookings/{bookingId} {
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    // Status fields must start at safe initial values — prevents pre-paid booking fraud
                    && request.resource.data.paymentStatus == "pending"
                    && request.resource.data.bookingStatus == "pending"
                    && request.resource.data.coinsStatus   == "pending"
                    && request.resource.data.coinsEarned   == 0
                    // Payment tracking fields are set exclusively by the payment API (Admin SDK)
                    && !request.resource.data.keys().hasAny(['tx_ref', 'paymentInitiatedAt'])
                    // Guest count validation
                    && request.resource.data.guests is int
                    && request.resource.data.guests >= 1
                    && request.resource.data.guests <= 10;

      allow read:   if isOwner(resource.data.userId) || isAdmin();

      // LOCKED: users may ONLY update specialRequests and phone (safe UX fields).
      // ALL financial, status, and loyalty fields are server-only.
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId)
         && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['specialRequests', 'phone', 'updatedAt'])
        );

      allow delete: if isAdmin();
    }

    // ── referrals ─────────────────────────────────────────────────────────
    // Immutable once created. referrerId must match the authenticated caller.
    // Only the referrer or the referred user may read their specific record.

    match /referrals/{referralId} {
      // Scoped read: only the involved users (not global list)
      allow read:   if isAdmin() ||
        (isAuthenticated() &&
          (request.auth.uid == resource.data.referrerId ||
           request.auth.uid == resource.data.referredUserId));
      // Client-side referral creation: referrerId MUST match the caller
      allow create: if isAuthenticated() &&
        request.resource.data.referrerId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── auditLogs ─────────────────────────────────────────────────────────
    // Append-only. Never updated or deleted.

    match /auditLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── subscribers ───────────────────────────────────────────────────────────
    // Public newsletter signup — no login required.
    // The addSubscriber() service:
    //   1. Queries (LIST) to check for duplicate email
    //   2. Creates new doc (CREATE) if not found
    //   3. Updates existing doc (UPDATE) to reactivate if found inactive
    // All three must be allowed for unauthenticated visitors.

    match /subscribers/{subscriberId} {
      // Public read needed for the duplicate-email query in addSubscriber().
      // Acceptable tradeoff: email addresses are voluntarily submitted for a newsletter.
      allow read: if true;

      // Public create with field-level validation to block garbage data.
      allow create: if request.resource.data.keys().hasAll(['email', 'status', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 4
        && request.resource.data.email.size() <= 254
        && request.resource.data.status == "active";

      // Public update ONLY to reactivate an existing subscription (status → active).
      // Prevents any other field from being tampered with.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status == "active"
      );

      allow delete: if isAdmin();
    }

    // ── newsletters ───────────────────────────────────────────────────────

    match /newsletters/{newsletterId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── news ──────────────────────────────────────────────────────────────

    match /news/{newsId} {
      allow read:   if resource.data.status == "published" || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── loyaltyTransactions (top-level mirror) ────────────────────────────
    // Written only by server (Admin SDK). Users can read their own records.

    match /loyaltyTransactions/{txId} {
      allow read:   if isAdmin() ||
        (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── rewards (legacy flat collection) ──────────────────────────────────

    match /rewards/{rewardId} {
      allow read:   if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

  }
}
